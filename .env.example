# .env.example — copy to .env for local overrides
# Never commit .env to git
#
# Email notifications are handled by the Cloudflare Worker relay.
# SMTP credentials are stored in Cloudflare secrets — not here.
# NOTIFY_URL and NOTIFY_TOKEN are baked into the pre-built Docker image,
# so desktop users need no .env at all.
#
# Only fill these in if you are building the image locally without
# GitHub Actions (e.g. docker compose up --build).

# NOTIFY_URL=https://deseq2-notify.<your-subdomain>.workers.dev/send
# NOTIFY_TOKEN=your-relay-token

APP_URL=http://localhost:3000

# Override data paths if needed
# DB_PATH=/data/sessions.db
# UPLOAD_DIR=/data/uploads
# RESULTS_DIR=/data/results
